<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>br.ufscar.advanse.xtract-plugin-intellij</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>Xtract</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://www.advanse.ufscar.br/pt-br">Advanced Research in Software Engineering</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
    <description><![CDATA[
    Xtract plugin for Intellij IDEA.
    The following functionalities are provided:
    <ul>
        <li>Analysis of a selected method code and estimation of refactoring applicability.</li>
        <li>Highlight of the code fragment identified as a candidate for the Extract Method refactoring.</li>
        <li>Textual explanation of the motivation behind the refactoring of the fragment through Extract Method.</li>
    </ul>
  ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">

    </extensions>

    <depends>com.intellij.java</depends>

    <actions>
        <group
                id="AnalyzeMethodRefactoringRecommendation"
                text="Analyze Method for Refactoring Opportunities"
                description="Analyze method code for refactoring opportunities"
                popup="true">
            <add-to-group
                    group-id="EditorPopupMenu"
                    anchor="after"
                    relative-to-action="RefactoringMenu"/>
            <action
                    id="br.ufscar.advanse.xtractpluginintellij.AnalyzeMethodRefactoringAction"
                    class="br.ufscar.advanse.xtractpluginintellij.AnalyzeMethodRefactoringAction"
                    text="Extract Method"
                    description="Extract method">
            </action>
        </group>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Refactoring Recommendation"
                    factoryClass="br.ufscar.advanse.xtractpluginintellij.RefactoringRecommendationToolWindowFactory"
                    icon="AllIcons.Nodes.Plugin"
                    anchor="right"/>
    </extensions>

</idea-plugin>